---
import { siteConfig } from "../config";
import { ui } from "../i18n/ui";
import LanguageToggle from "./LanguageToggle.astro";
import type { Lang } from "../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const content = siteConfig[lang];
const t = ui[lang].nav;

const hasProjects = content.projects && content.projects.length > 0;
const hasExperience = content.experience && content.experience.length > 0;
const hasEducation = content.education && content.education.length > 0;
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <nav class="max-w-7xl mx-auto px-4 sm:px-8 py-4">
    <div class="flex items-center justify-between">
      <ul class="hidden md:flex items-center gap-8">
        <li>
          <a
            href="#about"
            class="text-gray-700 hover:text-black transition-colors font-medium text-base sm:text-lg md:text-xl"
          >
            {t.about}
          </a>
        </li>
        {
          hasProjects && (
            <li>
              <a
                href="#projects"
                class="text-gray-700 hover:text-black transition-colors font-medium text-base sm:text-lg md:text-xl"
              >
                {t.projects}
              </a>
            </li>
          )
        }
        {
          hasExperience && (
            <li>
              <a
                href="#experience"
                class="text-gray-700 hover:text-black transition-colors font-medium text-base sm:text-lg md:text-xl"
              >
                {t.experience}
              </a>
            </li>
          )
        }
        {
          hasEducation && (
            <li>
              <a
                href="#education"
                class="text-gray-700 hover:text-black transition-colors font-medium text-base sm:text-lg md:text-xl"
              >
                {t.education}
              </a>
            </li>
          )
        }
      </ul>
      <LanguageToggle lang={lang} />
    </div>
  </nav>
</header>

<script>
  window.addEventListener("scroll", () => {
    const header = document.getElementById("header");
    if (window.scrollY > 100) {
      header?.classList.add("bg-white/80", "backdrop-blur-sm");
    } else {
      header?.classList.remove("bg-white/80", "backdrop-blur-sm");
    }
  });
</script>

<style>
  html {
    scroll-behavior: smooth;
  }
</style>

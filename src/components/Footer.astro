---
import { siteConfig } from "../config";
import { ui } from "../i18n/ui";
import type { Lang } from "../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const content = siteConfig[lang];
const t = ui[lang].footer;

const hasProjects = content.projects && content.projects.length > 0;
const hasExperience = content.experience && content.experience.length > 0;
const hasEducation = content.education && content.education.length > 0;
---

<footer class="relative bg-gray-50 border-t border-gray-200">
  <div class="mx-auto max-w-6xl px-6 py-12 lg:px-8">
    <div
      class="flex flex-col md:flex-row md:items-center md:justify-between gap-8"
    >
      <div class="flex flex-col gap-4">
        <h3 class="text-2xl font-bold text-gray-800">
          {content.name}
        </h3>
        <p class="text-base text-gray-600">
          {content.title}
        </p>
        <div class="flex gap-x-6">
          {
            siteConfig.social?.email_outlook ? (
              <a
                href={`mailto:${siteConfig.social.email_outlook}`}
                aria-label="Outlook"
                class="text-gray-600 transition-colors duration-300 hover:text-[var(--accent-color)]"
                style={`--accent-color: ${siteConfig.accentColor}`}
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="h-6 w-6"
                >
                  <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
                  <path d="M13.5 19h-8.5a2 2 0 0 1 -2 -2v-10a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v3.5"></path>
                  <path d="M21 15h-2.5a1.5 1.5 0 0 0 0 3h1a1.5 1.5 0 0 1 0 3h-2.5"></path>
                  <path d="M19 21v1m0 -8v1"></path>
                  <path d="M3 7l9 6l9 -6"></path>
                </svg>
              </a>
            ) : null
          }
          {
            siteConfig.social?.email_yeah ? (
              <a
                href={`mailto:${siteConfig.social.email_yeah}`}
                aria-label="Yeah Email"
                class="text-gray-600 transition-colors duration-300 hover:text-[var(--accent-color)]"
                style={`--accent-color: ${siteConfig.accentColor}`}
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="h-6 w-6"
                >
                  <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
                  <path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10"></path>
                  <path d="M3 7l9 6l9 -6"></path>
                </svg>
              </a>
            ) : null
          }
          {
            siteConfig.social?.github ? (
              <a
                href={siteConfig.social.github}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="GitHub"
                class="text-gray-600 transition-colors duration-300 hover:text-[var(--accent-color)]"
                style={`--accent-color: ${siteConfig.accentColor}`}
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="h-6 w-6"
                  ><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
                    d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5"
                  ></path></svg
                >
              </a>
            ) : null
          }
          {
            siteConfig.social?.qq ? (
              <a
                href={siteConfig.social.qq}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="QQ"
                class="text-gray-600 transition-colors duration-300 hover:text-[var(--accent-color)]"
                style={`--accent-color: ${siteConfig.accentColor}`}
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="h-6 w-6"
                >
                  <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
                  <path d="M6 9.748a14.716 14.716 0 0 0 11.995 -.052c.275 -9.236 -11.104 -11.256 -11.995 .052"></path>
                  <path d="M18 10c.984 2.762 1.949 4.765 2 7.153c.014 .688 -.664 1.346 -1.184 .303c-.346 -.696 -.952 -1.181 -1.816 -1.456"></path>
                  <path d="M17 16c.031 1.831 .147 3.102 -1 4"></path>
                  <path d="M8 20c-1.099 -.87 -.914 -2.24 -1 -4"></path>
                  <path d="M6 10c-.783 2.338 -1.742 4.12 -1.968 6.43c-.217 2.227 .716 1.644 1.16 .917c.296 -.487 .898 -.934 1.808 -1.347"></path>
                  <path d="M15.898 13l-.476 -2"></path>
                  <path d="M8 20l-1.5 1c-.5 .5 -.5 1 .5 1h10c1 0 1 -.5 .5 -1l-1.5 -1"></path>
                  <path d="M12.75 7a1 1 0 1 0 2 0a1 1 0 1 0 -2 0"></path>
                  <path d="M9.25 7a1 1 0 1 0 2 0a1 1 0 1 0 -2 0"></path>
                </svg>
              </a>
            ) : null
          }
        </div>
      </div>

      <div class="hidden md:block flex flex-col md:items-end gap-4">
        <nav class="flex gap-x-8">
          <a
            href="#about"
            class="text-sm text-gray-600 hover:text-gray-800 transition-colors"
            >{t.about}</a
          >
          {
            hasProjects && (
              <a
                href="#projects"
                class="text-sm text-gray-600 hover:text-gray-800 transition-colors"
              >
                {t.projects}
              </a>
            )
          }
          {
            hasExperience && (
              <a
                href="#experience"
                class="text-sm text-gray-600 hover:text-gray-800 transition-colors"
              >
                {t.experience}
              </a>
            )
          }
          {
            hasEducation && (
              <a
                href="#education"
                class="text-sm text-gray-600 hover:text-gray-800 transition-colors"
              >
                {t.education}
              </a>
            )
          }
        </nav>
        <p class="text-sm text-gray-500">
          &copy; {new Date().getFullYear()}
          {content.name}. {t.allRightsReserved}
        </p>
        <p class="text-xs text-gray-400">
          <a
            href="https://beian.miit.gov.cn/"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-gray-600 transition-colors no-underline"
          >
            {siteConfig.icp}
          </a>
          <span class="mx-2">|</span>
          <a
            href="https://beian.mps.gov.cn/#/query/webSearch?code=32040402001123"
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center gap-1.5 hover:text-gray-600 transition-colors no-underline"
          >
            <img
              src="/beian-police.png"
              alt="公安徽标"
              width="13"
              height="14"
              class="inline-block align-middle"
            />
            苏公网安备32040402001123号
          </a>
        </p>
      </div>
    </div>
  </div>

  <div class="absolute inset-0 -z-10 overflow-hidden">
    <svg
      aria-hidden="true"
      class="absolute bottom-0 left-0 w-full h-24 text-gray-100"
    >
      <pattern
        id="footer-pattern"
        x="0"
        y="0"
        width="100"
        height="100"
        patternUnits="userSpaceOnUse"
      >
        <path
          d="M0 50 Q 25 40, 50 50 T 100 50"
          stroke="currentColor"
          stroke-width="0.5"
          fill="none"
          opacity="0.4"></path>
      </pattern>
      <rect width="100%" height="100%" fill="url(#footer-pattern)"></rect>
    </svg>
  </div>
</footer>
